{
  "name": "op-anthropic-auth",
  "version": "0.1.3",
  "description": "OpenCode plugin for Anthropic OAuth with Claude Pro/Max",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leohenon/op-anthropic-auth"
  },
  "homepage": "https://github.com/leohenon/op-anthropic-auth#readme",
  "bugs": {
    "url": "https://github.com/leohenon/op-anthropic-auth/issues"
  },
  "keywords": [
    "opencode",
    "anthropic",
    "claude",
    "oauth",
    "auth",
    "plugin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "smoke": "npm run build && node ./dist/smoke.js",
    "smoke:refresh": "npm run build && ANTHROPIC_SMOKE_REFRESH=1 node ./dist/smoke.js",
    "prepublishOnly": "npm run build && npm run smoke"
  },
  "dependencies": {
    "@openauthjs/openauth": "^0.4.3"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.3",
    "@types/node": "^24.6.1",
    "typescript": "^5.9.3"
  }
}
